{
  "name": "bitrise-api-cli",
  "version": "0.1.0",
  "description": "Download the latest Bitrise build artifacts for a workflow from the command line.",
  "module": "index",
  "type": "module",
  "bin": {
    "bitrise-api-cli": "dist/cli.js"
  },
  "keywords": [
    "bitrise",
    "bitriseio",
    "ci",
    "artifacts",
    "apk",
    "ipa",
    "download",
    "cli"
  ],
  "author": {
    "name": "WookieFPV (Lukas Müller)",
    "url": "https://github.com/WookieFPV"
  },
  "license": "MIT",
  "main": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WookieFPV/bitrise-api-cli.git"
  },
  "homepage": "https://github.com/WookieFPV/bitrise-api-cli#readme",
  "bugs": {
    "url": "https://github.com/WookieFPV/bitrise-api-cli/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch --clean false",
    "lint": "bunx biome check --fix",
    "lint:CI": "bunx biome check",
    "typecheck": "tsc",
    "api:update": "curl -f \"https://api-docs.bitrise.io/docs/swagger.json\" -o \"src/bitrise/openapi.json\"",
    "api:codegen": "openapi-generator-cli generate -g typescript-fetch --additional-properties=useSingleRequestParameter=true -o ./src/generated_api -i src/bitrise/openapi.json && npm run lint",
    "prepublishOnly": "bun i && bun run lint:CI && tsc  && bun run build"
  },
  "dependencies": {
    "@stricli/core": "1.3.0",
    "cosmiconfig": "9.0.2",
    "ora": "9.4.1",
    "zx": "8.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@openapitools/openapi-generator-cli": "2.40.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "tsup": "8.5.1",
    "typescript": "7.0.2"
  },
  "overrides": {
    "brace-expansion": "2.1.2",
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "glob": "10.5.0",
    "ip-address": "10.2.0",
    "js-yaml": "4.3.0",
    "minimatch": "9.0.9",
    "picomatch": "4.0.4",
    "rollup": "4.60.4",
    "shell-quote": "1.9.0"
  }
}
