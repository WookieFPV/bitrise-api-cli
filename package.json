{
  "name": "bitrise-api-cli",
  "version": "0.0.12",
  "description": "Download the latest Bitrise build artifacts for a workflow from the command line.",
  "module": "index",
  "type": "module",
  "bin": {
    "bitrise-api-cli": "./dist/cli.js"
  },
  "keywords": ["bitrise", "bitriseio", "ci", "artifacts", "apk", "ipa", "download", "cli"],
  "author": {
    "name": "WookieFPV (Lukas Müller)",
    "url": "https://github.com/WookieFPV"
  },
  "license": "MIT",
  "main": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WookieFPV/bitrise_api_cli.git"
  },
  "homepage": "https://github.com/WookieFPV/bitrise_api_cli#readme",
  "bugs": {
    "url": "https://github.com/WookieFPV/bitrise_api_cli/issues"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch --clean false",
    "lint": "bunx biome check --fix",
    "lint:CI": "bunx biome check",
    "typecheck": "tsc",
    "api:update": "curl -f \"https://api-docs.bitrise.io/docs/swagger.json\" -o \"src/bitrise/openapi.json\"",
    "api:codegen": "openapi-generator-cli generate -g typescript-fetch --additional-properties=useSingleRequestParameter=true -o ./src/generated_api -i src/bitrise/openapi.json && npm run lint",
    "prepublishOnly": "bun i && bun run lint:CI && tsc  && bun run build"
  },
  "dependencies": {
    "@stricli/core": "1.2.7",
    "cosmiconfig": "9.0.1",
    "ora": "9.4.0",
    "zx": "8.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@openapitools/openapi-generator-cli": "2.34.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "brace-expansion": "2.1.1",
    "glob": "10.5.0",
    "ip-address": "10.2.0",
    "js-yaml": "4.1.1",
    "minimatch": "9.0.9",
    "picomatch": "4.0.4",
    "rollup": "4.60.4"
  }
}
